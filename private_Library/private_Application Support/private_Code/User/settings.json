{
    /// 外观
    "editor.fontSize": 14, // 设置字体大小
    "editor.wordWrap": "wordWrapColumn", // 常规编辑器是否自动换行, 在指定列数处换行
    "editor.wordWrapColumn": 120, // 在120列处换行
    "diffEditor.wordWrap": "on", // 差异对比编辑器是否自动换行, 视口宽度换行
    "diffEditor.hideUnchangedRegions.enabled": true, // 差异对比编辑器显示未更改的区域
    "diffEditor.ignoreTrimWhitespace": false, // 差异对比编辑器忽略前导空格或尾随空格中的更改
    "editor.rulers": [ // 垂直标尺 
        120
    ],
    "editor.fontFamily": "Maple Mono Normal NF, JetBrains Mono, SF Mono, Monaco", // 设置字体
    "editor.fontLigatures": true, // 开启字体连字
    "editor.renderWhitespace": "all", // 显示空白字符
    "editor.guides.bracketPairs": "active", // 仅为活动括号对启用括号对参考线
    "editor.selectionHighlight": false, // 编辑器是否应突出显示与所选内容类似的匹配项
    "workbench.colorTheme": "Dark+", // 工作台中使用的颜色主题
    "workbench.iconTheme": "material-icon-theme", // 工作台中使用的文件图标主题
    "workbench.colorCustomizations": { // 覆盖当前所选颜色主题的颜色
        "editor.lineHighlightBackground": "#1073cf2d", // 光标所在行高亮内容的背景颜色
        "editor.lineHighlightBorder": "#9fced11f" // 光标所在行四周边框的背景颜色
    },
    /// 保存行为
    "files.autoSave": "afterDelay", // 自动保存(间隔1000ms)
    "editor.codeActionsOnSave": { // 代码保存时
        "source.organizeImports": "explicit", // 显式保存时运行imports整理
        "source.fixAll": "explicit", // 显式保存时自动修复 ESLint/TS 问题
    },
    /// 代码格式化
    "editor.formatOnType": true, // 换行时自动格式化
    "editor.formatOnPaste": true, // 粘贴时自动格式化
    "editor.formatOnSave": true, // 显式保存时自动格式化
    /// 代码补全
    "editor.suggestSelection": "recentlyUsedByPrefix", // 根据当前输入的前缀匹配最近使用过的项
    "editor.tabCompletion": "onlySnippets", // 在前缀匹配时进行 Tab 补全
    "editor.wordBasedSuggestions": "off", // 关闭根据文档中的字词计算补全
    /// 编辑器行为
    "git.openRepositoryInParentFolders": "never", // 不在工作区的父文件夹中打开存储库或打开文件
    "explorer.confirmDelete": false, // 在通过回收站删除文件时不要求确认
    "explorer.confirmDragAndDrop": false, // 在通过拖放移动文件或文件夹时不要求确认
    "explorer.confirmPasteNative": false, // 在粘贴本机文件和文件夹时不要求确认
    "workbench.startupEditor": "none", // 在没有从上一会话中恢复出信息的情况下, 启动时不打开编辑器
    "workbench.commandPalette.preserveInput": true, // 在命令面板中保留输入
    "explorer.fileNesting.enabled": true, // 在文件资源管理器中启用文件嵌套
    "explorer.fileNesting.patterns": { // 文件资源管理器中的文件嵌套模式
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*",
        "pubspec.yaml": "pubspec.lock,pubspec_overrides.yaml,.packages,.flutter-plugins,.flutter-plugins-dependencies,.metadata",
        "*.dart": "${capture}.g.dart,${capture}.freezed.dart",
    },
    "files.exclude": { // 在文件资源管理器中隐藏特定的文件和文件夹
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },
    "editor.stickyScroll.enabled": false, // 关闭粘性滚动
    "accessibility.signalOptions.volume": 0, // 关闭声音提醒
    /// Git
    "git.confirmSync": false, // 同步 Git 存储库时不要求确认
    /// 终端
    "terminal.external.osxExec": "iTerm.app", // 设置终端为 iTerm
    /// Dart
    "dart.previewFlutterUiGuides": true, // 启用Flutter UI 指南预览
    "dart.previewFlutterUiGuidesCustomTracking": true, // 启用flutter UI 指南的自定义跟踪
    "dart.closingLabels": false, // 不显示针对构造函数的注释, 方法调用和跨越多行的列表
    "dart.debugExternalPackageLibraries": true, // 调试外部依赖包代码
    "dart.debugSdkLibraries": true, // 调试 Dart SDK 内部代码
    "[markdown]": { // Markdown 设置
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint" // 设置默认格式化器
    },
    /// copilot
    "github.copilot.enable": { // 禁用 copilot
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    /// SSH扩展
    "remote.SSH.defaultExtensions": [
        "LiChenxi.sysmonitor"
    ],
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1"
}